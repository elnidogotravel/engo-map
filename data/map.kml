    <Folder>
      <name>行程地標</name>
      <Placemark>
        <name>Canopy Walk石灰岩爬山</name>
        <styleUrl>#icon-1596-F9A825-labelson-nodesc</styleUrl>
        <Point>
          <coordinates>
